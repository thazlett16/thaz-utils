{
  "name": "thaz-utils-devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "thaz-utils-devcontainer-user",
  "customizations" : {
    "jetbrains" : {
      "backend" : "WebStorm",
      "settings" : {},
      "plugins" : []
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installOhMyZsh": "false",
      "installOhMyZshConfig": "false",
      "username": "thaz-utils-devcontainer-user"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": "false"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "./features/vite-plus": {}
  },
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/thaz-utils-devcontainer-user/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.config/gh,target=/home/thaz-utils-devcontainer-user/.config/gh,type=bind,readonly",
    "source=${localEnv:HOME}/.local/share/pnpm/store,target=/home/thaz-utils-devcontainer-user/.local/share/pnpm/store,type=bind",
    "source=${localEnv:HOME}/.config/claude,target=/home/thaz-utils-devcontainer-user/.config/claude,type=bind"
  ],
  "forwardPorts": [],
  "postCreateCommand": "/bin/bash .devcontainer/postCreateCommand.sh"
}
