# Dependencies
node_modules/

# Local env files
.env*
!.env.example
*.local

# Build Outputs
build/
dist/
dist-ssr/
.output/
.tanstack/
*.tgz

# Test Outputs
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Logs
*.log*
pnpm-debug.log*

# Extra Folders
.idea/
.vscode/
!.vscode/extensions.json
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
